---
import { getEvents, urlFor } from '../utils/sanity';

const allEvents = await getEvents();
const now = new Date();

const upcomingEvents = allEvents
  .filter((event: any) => new Date(event.dateOfEvent) >= now)
  .sort((a: any, b: any) => new Date(a.dateOfEvent).getTime() - new Date(b.dateOfEvent).getTime());

const pastEvents = allEvents
  .filter((event: any) => new Date(event.dateOfEvent) < now)
  .sort((a: any, b: any) => new Date(b.dateOfEvent).getTime() - new Date(a.dateOfEvent).getTime());

const eventSections = [
  { title: "UPCOMING ACTIVITIES", subtitle: "UPCOMING EVENTS.", events: upcomingEvents, id: "upcoming" },
  { title: "PAST HIGHLIGHTS", subtitle: "PAST EVENTS.", events: pastEvents, id: "past" }
].filter(section => section.events.length > 0);
---

<section id="events" class="py-24 bg-brand-secondary overflow-hidden">
  {eventSections.map((section, idx) => (
    <div class={idx > 0 ? "mt-24" : ""}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
        <div class="flex flex-col md:flex-row justify-between items-end gap-6">
          <div class="max-w-xl">
            <h2 class="text-brand-accent font-black tracking-[0.2em] text-sm mb-4 uppercase">{section.title}</h2>
            <h3 class="text-4xl md:text-5xl font-black text-brand-primary tracking-tight">{section.subtitle}</h3>
          </div>
        </div>
      </div>

      <div class={`swiper-container-${section.id} max-w-7xl mx-auto px-4 sm:px-6 lg:px-8`}>
        <div class={`swiper swiper-${section.id}`}>
          <div class="swiper-wrapper py-10">
            {section.events.map((event: any) => (
              <div class="swiper-slide h-auto">
                <a 
                  href={event.fbEventLink || "#"} 
                  target={event.fbEventLink ? "_blank" : "_self"}
                  rel={event.fbEventLink ? "noopener noreferrer" : ""}
                  class="group block h-full bg-brand-primary rounded-[2.5rem] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 relative aspect-[4/5]"
                >
                  <div class="absolute inset-0">
                    {event.coverPhoto && (
                      <img
                        src={urlFor(event.coverPhoto).width(1000).url()}
                        alt={event.name}
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-80 group-hover:opacity-100"
                      />
                    )}
                  </div>
                  
                  <div class="absolute inset-0 bg-gradient-to-t from-brand-primary via-brand-primary/20 to-transparent opacity-90 transition-opacity duration-500"></div>

                  <div class="absolute top-8 left-8 z-20">
                    <span class="bg-brand-primary/40 backdrop-blur-md text-brand-secondary px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-[0.2em] border border-white/20 shadow-lg">
                      {event.category}
                    </span>
                  </div>

                  <div class="absolute bottom-0 left-0 right-0 p-10 z-20">
                    <div class="flex items-center gap-3 mb-4">
                      <span class="w-8 h-px bg-brand-accent"></span>
                      <p class="text-brand-accent font-black text-[11px] tracking-[0.3em] uppercase">
                        {new Date(event.dateOfEvent).toLocaleDateString('en-US', { 
                          month: 'short', 
                          day: 'numeric', 
                          year: 'numeric' 
                        })}
                      </p>
                    </div>
                    <h4 class="text-3xl font-black text-white mb-8 group-hover:text-brand-accent transition-colors leading-tight line-clamp-2">
                      {event.name}
                    </h4>
                    
                    {event.fbEventLink && (
                      <div class="inline-flex items-center gap-3 text-white/70 group-hover:text-white font-black text-[10px] tracking-[0.3em] transition-all uppercase">
                        VIEW ON FACEBOOK
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
                      </div>
                    )}
                  </div>
                </a>
              </div>
            ))}
          </div>
          <div class={`swiper-pagination swiper-pagination-${section.id} !-bottom-2`}></div>
        </div>
      </div>
    </div>
  ))}

  {eventSections.length === 0 && (
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center py-20 bg-gray-50 rounded-3xl border-2 border-dashed border-gray-200">
         <p class="text-gray-400 font-bold uppercase tracking-widest text-sm">No events to display</p>
      </div>
    </div>
  )}
</section>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.css" />

<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Autoplay } from 'swiper/modules';

  const swiperConfigs = {
    modules: [Navigation, Pagination, Autoplay],
    slidesPerView: 1,
    spaceBetween: 24,
    loop: false, // Changed to false for better navigation when few events
    autoplay: {
      delay: 5000,
      disableOnInteraction: false,
    },
    pagination: {
      clickable: true,
    },
    breakpoints: {
      768: {
        slidesPerView: 2,
      },
      1280: {
        slidesPerView: 3,
      },
    },
  };

  if (document.querySelector('.swiper-upcoming')) {
    new Swiper('.swiper-upcoming', {
      ...swiperConfigs,
      pagination: {
        el: '.swiper-pagination-upcoming',
        clickable: true,
      },
    });
  }

  if (document.querySelector('.swiper-past')) {
    new Swiper('.swiper-past', {
      ...swiperConfigs,
      pagination: {
        el: '.swiper-pagination-past',
        clickable: true,
      },
    });
  }
</script>

<style>
  .swiper-pagination-bullet-active {
    background: #d4af37 !important;
  }
</style>

