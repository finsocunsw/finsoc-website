---
const year = new Date().getFullYear();
---

<footer class="bg-gray-50 border-t border-gray-200 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="col-span-1 md:col-span-2">
        <span class="text-2xl font-bold bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">
          FinSoc
        </span>
        <p class="mt-4 text-gray-500 max-w-xs text-sm leading-relaxed">
          The Financial Society at our university. Empowering students with financial literacy and career opportunities.
        </p>
      </div>
      <div>
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Resources</h3>
        <ul class="mt-4 space-y-2">
          <li><a href="#" class="text-sm text-gray-500 hover:text-blue-600 transition-colors">Documentation</a></li>
          <li><a href="#" class="text-sm text-gray-500 hover:text-blue-600 transition-colors">Guides</a></li>
          <li><a href="#" class="text-sm text-gray-500 hover:text-blue-600 transition-colors">Help Center</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Social</h3>
        <ul class="mt-4 space-y-2">
          <li><a href="#" class="text-sm text-gray-500 hover:text-blue-600 transition-colors">LinkedIn</a></li>
          <li><a href="#" class="text-sm text-gray-500 hover:text-blue-600 transition-colors">Instagram</a></li>
          <li><a href="#" class="text-sm text-gray-500 hover:text-blue-600 transition-colors">Twitter</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-gray-200">
      <p class="text-xs text-gray-400 text-center">
        &copy; {year} Financial Society (FinSoc). All rights reserved.
      </p>
    </div>
  </div>
</footer>