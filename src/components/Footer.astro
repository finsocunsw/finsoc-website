---
const year = new Date().getFullYear();
---

<footer class="bg-brand-primary text-brand-secondary py-24 relative overflow-hidden">
  <div class="absolute inset-0 opacity-5 pointer-events-none">
     <div class="absolute bottom-0 right-0 w-1/2 h-1/2 bg-brand-accent rounded-full blur-[180px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-16 md:gap-8">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center gap-2 mb-8 group">
          <img 
            src="/logo.png" 
            alt="FINSOC logo" 
            class="h-12 w-auto object-contain"
          />
        </div>
        <div class="mt-10 flex items-center gap-6">
          <a href="https://www.linkedin.com/company/unsw-finsoc" class="w-12 h-12 rounded-[0.5rem] bg-brand-secondary/5 flex items-center justify-center hover:bg-brand-accent hover:text-brand-primary transition-all group">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="https://www.instagram.com/unswfinsoc/" class="w-12 h-12 rounded-[0.5rem] bg-brand-secondary/5 flex items-center justify-center hover:bg-brand-accent hover:text-brand-primary transition-all group">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <a href="https://www.facebook.com/FINSOCUNSW/" class="w-12 h-12 rounded-[0.5rem] bg-brand-secondary/5 flex items-center justify-center hover:bg-brand-accent hover:text-brand-primary transition-all group">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        </div>
      </div>
      
      <div>
        <h3 class="text-brand-accent font-black tracking-widest text-xs uppercase mb-8">Navigation</h3>
        <ul class="space-y-4">
          <li><a href="/our-team" class="text-gray-400 hover:text-brand-secondary transition-colors font-bold uppercase tracking-wider text-sm">Our Team</a></li>
          <li><a href="/#events" class="text-gray-400 hover:text-brand-secondary transition-colors font-bold uppercase tracking-wider text-sm">Events</a></li>
          <li><a href="/affiliations" class="text-gray-400 hover:text-brand-secondary transition-colors font-bold uppercase tracking-wider text-sm">Affiliations</a></li>
          <li><a href="/publications" class="text-gray-400 hover:text-brand-secondary transition-colors font-bold uppercase tracking-wider text-sm">Publications</a></li>
        </ul>
      </div>
      
      <div>
        <h3 class="text-brand-accent font-black tracking-widest text-xs uppercase mb-8">Resources</h3>
        <ul class="space-y-4">
          <li><a href="https://campus.hellorubric.com/?tab=memberships&s=12537" class="text-gray-400 hover:text-brand-secondary transition-colors font-bold uppercase tracking-wider text-sm">Join Us</a></li>
          <li><a href="mailto:admin@unswfinsoc.org" class="text-gray-400 hover:text-brand-secondary transition-colors font-bold uppercase tracking-wider text-sm">Contact Us</a></li>
        </ul>
      </div>
    </div>
    
    <div class="mt-24 pt-8 border-t border-brand-secondary/10 flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="text-xs text-gray-500 font-bold tracking-widest uppercase text-center md:text-left">
        &copy; {year} UNSW FINSOC
      </p>
      <div class="flex gap-10">
      </div>
    </div>
  </div>
</footer>
