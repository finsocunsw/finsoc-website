<section id="join" class="py-24 bg-brand-secondary">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-brand-primary rounded-[3rem] p-12 md:p-24 relative overflow-hidden flex flex-col items-center text-center group">
       <div class="absolute inset-0 bg-brand-accent/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
       <div class="absolute -top-24 -right-24 w-64 h-64 bg-brand-accent/20 rounded-full blur-3xl"></div>
       <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-brand-accent/20 rounded-full blur-3xl"></div>
       
       <h2 class="text-brand-accent font-black tracking-[0.2em] text-sm mb-6 uppercase">START YOUR JOURNEY</h2>
       <h3 class="text-5xl md:text-7xl font-black text-brand-secondary leading-tight tracking-tighter mb-10 max-w-4xl">
         READY TO <span class="italic text-brand-accent underline decoration-brand-accent/30 decoration-8 underline-offset-8">DOMINATE</span> THE FINANCIAL LANDSCAPE?
       </h3>
       <p class="text-xl text-gray-400 font-medium max-w-2xl mb-12">
         Membership is now open for the upcoming semester. Secure your spot in the premier student-led financial community today.
       </p>
       
       <div class="flex flex-wrap justify-center gap-8">
          <a href="/join-us" class="bg-brand-accent text-brand-primary px-16 py-6 rounded-2xl text-xl font-black hover:bg-brand-secondary hover:scale-105 transition-all shadow-2xl shadow-brand-accent/30 flex items-center gap-3">
             APPLY NOW
             <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
       </div>
       
       <p class="mt-12 text-gray-500 font-bold uppercase tracking-widest text-xs">Applications close on October 1st, 2026</p>
    </div>
  </div>
</section>
