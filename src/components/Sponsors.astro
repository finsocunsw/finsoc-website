---
import { getSponsors, urlFor } from '../utils/sanity';

const sponsors = await getSponsors();

const tiers = ['platinum', 'gold', 'silver', 'bronze'];

const sponsorsByTier = tiers.reduce((acc, tier) => {
  acc[tier] = sponsors.filter((s: any) => s.sponsorTier === tier);
  return acc;
}, {} as Record<string, any[]>);
---

<section id="sponsors" class="bg-gray-50 py-24 border-y border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-brand-accent font-black tracking-[0.2em] text-sm mb-4">OUR AFFILIATIONS</h2>
      <h3 class="text-4xl md:text-5xl font-black text-brand-primary">SUPPORTED BY LEADERS.</h3>
    </div>

    <div class="space-y-20">
      {tiers.map((tier) => sponsorsByTier[tier]?.length > 0 && (
        <div class="tier-group">
          <h4 class="text-center text-xs font-bold text-gray-400 uppercase tracking-[0.3em] mb-10 flex items-center justify-center gap-4">
            <span class="h-px bg-gray-200 w-16"></span>
            {tier} PARTNERS
            <span class="h-px bg-gray-200 w-16"></span>
          </h4>
          <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16">
            {sponsorsByTier[tier].map((sponsor: any) => (
              <div class="group relative">
                <div class="absolute inset-0 bg-brand-accent/5 rounded-2xl blur-xl group-hover:bg-brand-accent/10 transition-colors"></div>
                {sponsor.logo ? (
                  <img
                    src={urlFor(sponsor.logo).width(300).url()}
                    alt={sponsor.name}
                    class="h-12 md:h-16 w-auto object-contain grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500 relative z-10"
                  />
                ) : (
                   <span class="text-xl font-bold text-gray-300 relative z-10">{sponsor.name}</span>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
      
      {sponsors.length === 0 && (
         <div class="text-center py-10 opacity-50 italic">
           Sponsors being updated for the current academic year.
         </div>
      )}
    </div>
  </div>
</section>
