---
import { getSponsors, urlFor } from '../utils/sanity';

const sponsors = await getSponsors();

// Create a duplicated list for seamless looping
const duplicatedSponsors = [...sponsors, ...sponsors];
---

<section id="sponsors" class="bg-white py-20 overflow-hidden border-y border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
    <div class="text-center">
      <h2 class="text-brand-accent font-black tracking-[0.2em] text-sm mb-4">OUR AFFILIATIONS</h2>
      <h3 class="text-3xl md:text-4xl font-black text-brand-primary uppercase">Supported by industry leaders.</h3>
    </div>
  </div>

  <div class="relative flex overflow-x-hidden">
    <div class="py-12 animate-marquee flex items-center whitespace-nowrap">
      {duplicatedSponsors.map((sponsor: any) => (
        <div class="mx-8 md:mx-16 flex-shrink-0">
          {sponsor.logo ? (
            <img
              src={urlFor(sponsor.logo).height(80).url()}
              alt={sponsor.name}
              class="h-12 md:h-16 w-auto object-contain transition-all duration-500"
            />
          ) : (
            <span class="text-xl font-bold text-gray-400">{sponsor.name}</span>
          )}
        </div>
      ))}
    </div>

    <!-- Second set of logos for the seamless loop -->
    <div class="absolute top-0 py-12 animate-marquee2 flex items-center whitespace-nowrap">
      {duplicatedSponsors.map((sponsor: any) => (
        <div class="mx-8 md:mx-16 flex-shrink-0">
          {sponsor.logo ? (
            <img
              src={urlFor(sponsor.logo).height(80).url()}
              alt={sponsor.name}
              class="h-12 md:h-16 w-auto object-contain transition-all duration-500"
            />
          ) : (
            <span class="text-xl font-bold text-gray-400">{sponsor.name}</span>
          )}
        </div>
      ))}
    </div>
  </div>

  <div class="text-center mt-12">
    <a href="/affiliations" class="text-brand-accent font-bold hover:underline inline-flex items-center gap-2">
      View all affiliations
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </a>
  </div>
</section>

<style>
  .animate-marquee {
    animation: marquee 40s linear infinite;
  }

  .animate-marquee2 {
    animation: marquee2 40s linear infinite;
  }

  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-100%); }
  }

  @keyframes marquee2 {
    0% { transform: translateX(100%); }
    100% { transform: translateX(0%); }
  }

  /* Pause on hover */
  .relative:hover .animate-marquee,
  .relative:hover .animate-marquee2 {
    animation-play-state: paused;
  }
</style>
