---
const testimonials = [
  {
    quote: "What I appreciated the most about the sponsorships subcommittee was the opportunity to make meaningful and long-lasting friendships. With my FINSOC friends, we've been hitting up different food spots in Sydney, planning classes together and making amazing memories through road trips and fun FINSOC events.",
    author: "Ariana Lai",
    role: "Sponsorships Subcommittee 2022",
  },
  {
    quote: "Joining FINSOC publications helped fulfil university life and connected me with like-minded students, many who I call my closest friends. Being part of the society, gave me industry experience without needing to have my foot in the door, which is why joining FINSOC subcommittee is something that I certainly recommend!",
    author: "Justin Nelson",
    role: "Publications Subcommittee 2022",
  },
];
---

<section id="testimonials" class="py-24 bg-brand-primary relative overflow-hidden">
  <div class="absolute inset-0 opacity-5">
     <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full border-[200px] border-brand-accent rounded-full"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-brand-accent font-black tracking-[0.2em] text-sm mb-4 uppercase">TESTIMONIALS</h2>
      <h3 class="text-4xl md:text-5xl font-black text-brand-secondary">HEAR FROM OUR MEMBERS.</h3>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      {testimonials.map((t) => (
        <div class="bg-brand-secondary/5 backdrop-blur-sm p-10 rounded-[2.5rem] border border-brand-secondary/10 flex flex-col hover:bg-brand-secondary/10 transition-colors group">
          <div class="mb-8">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-accent opacity-50 group-hover:opacity-100 transition-opacity"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 2.5 1 4.066 2 5V21Z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h1.5c0 1.25 0 1 0 1v1c0 2.5 1 4.066 2 5V21Z"/></svg>
          </div>
          <p class="text-xl text-gray-300 font-medium italic leading-relaxed mb-10 flex-grow">
            "{t.quote}"
          </p>
          <div class="flex items-center gap-5 mt-auto">
            <div class="w-14 h-14 bg-brand-accent rounded-2xl flex items-center justify-center font-black text-brand-primary text-xl shadow-lg shadow-brand-accent/20">
              {t.avatar}
            </div>
            <div>
              <p class="text-brand-secondary font-black text-lg tracking-tight">{t.author}</p>
              <p class="text-brand-accent text-sm font-bold uppercase tracking-widest">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
