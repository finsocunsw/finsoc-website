---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Sponsors from '../components/Sponsors.astro';
import EventsCarousel from '../components/EventsCarousel.astro';
import Testimonials from '../components/Testimonials.astro';
import JoinSection from '../components/JoinSection.astro';
import PublicationSlideshow from '../components/PublicationSlideshow.astro';
import { urlFor, getLatestPublication } from '../utils/sanity';

export const prerender = true;

const latestPublication = await getLatestPublication();
---

<Layout title="UNSW FINSOC">
  <Hero />
  
  <Sponsors />
  
  <EventsCarousel />

  <section id="latest-publication" class="py-16 md:py-24 bg-gray-50 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mb-12 md:mb-16">
        <div class="max-w-xl text-left">
          <h2 class="text-brand-accent font-black tracking-[0.2em] text-sm mb-4 uppercase">OUR LATEST ISSUE</h2>
          <h3 class="text-3xl md:text-5xl font-black text-brand-primary tracking-tight">PUBLICATIONS.</h3>
        </div>
        <a href="/publications" class="text-brand-primary font-bold border-b-2 border-brand-accent hover:text-brand-accent transition-colors pb-1 uppercase tracking-wider text-sm">VIEW ALL PUBLICATIONS</a>
      </div>

      {latestPublication ? (
        <div class="space-y-12">
          <PublicationSlideshow slides={latestPublication.slides} title={latestPublication.title} />
        </div>
      ) : (
        <div class="py-20 text-center bg-white rounded-[0.5rem] border-4 border-dashed border-gray-100">
          <p class="text-gray-400 font-bold uppercase tracking-widest text-sm">No publications found yet.</p>
        </div>
      )}
    </div>
  </section>

  <Testimonials />
  
  <JoinSection />
</Layout>
