---
import Layout from '../layouts/Layout.astro';
---

<Layout title="FinSoc | Financial Society">
	<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32">
		<div class="max-w-3xl">
			<h1 class="text-5xl md:text-7xl font-extrabold text-gray-900 tracking-tight">
				Bridging the gap between <span class="bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent italic">finance</span> and students.
			</h1>
			<p class="mt-8 text-xl text-gray-500 leading-relaxed max-w-2xl">
				Join the premier financial community on campus. We provide the tools, network, and knowledge to help you excel in your professional journey.
			</p>
			<div class="mt-10 flex flex-wrap gap-4">
				<button class="bg-blue-600 text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-blue-700 transition-all shadow-md hover:shadow-lg active:scale-95">
					Join Today
				</button>
				<button class="bg-white text-gray-900 border border-gray-200 px-8 py-4 rounded-full text-lg font-semibold hover:bg-gray-50 transition-all active:scale-95">
					Learn More
				</button>
			</div>
		</div>
	</section>
</Layout>
