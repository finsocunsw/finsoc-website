---
import Layout from '../../layouts/Layout.astro';
import PublicationSlideshow from '../../components/PublicationSlideshow.astro';
import { getPublication, getPublications } from '../../utils/sanity';

export async function getStaticPaths() {
  const publications = await getPublications();
  return publications.map((pub: any) => ({
    params: { slug: pub.slug.current },
  }));
}

const { slug } = Astro.params;
const publication = await getPublication(slug!);

if (!publication) {
  return Astro.redirect('/404');
}
---

<Layout title={`${publication.title} | Publications`}>
  <main class="pt-32 pb-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center mb-16">
        <a href="/publications" class="inline-flex items-center gap-2 text-brand-accent font-black text-[10px] uppercase tracking-[0.2em] mb-8 hover:gap-3 transition-all group">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform"><path d="m15 18-6-6 6-6"/></svg>
          BACK TO ARCHIVE
        </a>
        <h1 class="text-4xl md:text-6xl font-black text-brand-primary tracking-tight mb-6 leading-tight">{publication.title}</h1>
        <div class="flex items-center justify-center gap-4 mb-8">
           <span class="text-gray-400 font-bold uppercase tracking-widest text-xs">Published {new Date(publication.publishedAt).toLocaleDateString()}</span>
           <span class="w-1.5 h-1.5 rounded-full bg-brand-accent"></span>
           <span class="text-gray-400 font-bold uppercase tracking-widest text-xs">{publication.slides.length} Pages</span>
        </div>
        <p class="text-xl text-gray-500 font-medium leading-relaxed max-w-2xl mx-auto">
          {publication.excerpt}
        </p>
      </div>

      <PublicationSlideshow slides={publication.slides} title={publication.title} />
    </div>
  </main>
</Layout>
