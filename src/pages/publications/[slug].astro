---
import Layout from '../../layouts/Layout.astro';
import PublicationSlideshow from '../../components/PublicationSlideshow.astro';
import { getPublication, getPublications } from '../../utils/sanity';

export async function getStaticPaths() {
  const publications = await getPublications();
  return publications.map((pub: any) => ({
    params: { slug: pub.slug.current },
  }));
}

const { slug } = Astro.params;
const publication = await getPublication(slug!);

if (!publication) {
  return Astro.redirect('/404');
}

const formatDate = (date: string) => {
  return new Date(date).toLocaleDateString('en-AU', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
};
---

<Layout title={`${publication.title} | FINSOC Review`}>
  <main class="pt-12 pb-24 afr-theme">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      
      <!-- Back Link -->
      <div class="mb-12 border-b border-afr-border pb-4">
        <a href="/publications" class="inline-flex items-center gap-2 font-sans font-black text-[10px] uppercase tracking-[0.2em] text-afr-red hover:gap-3 transition-all">
          ← BACK TO ARCHIVE
        </a>
      </div>

      <!-- Article Header -->
      <div class="max-w-4xl mx-auto mb-16">
        <div class="space-y-6">
          <div class="flex items-center gap-3 font-sans text-xs font-black uppercase tracking-[0.2em] text-afr-red">
            <span>FINSOC WEEKLY WRAPS</span>
            <span class="w-1 h-1 bg-afr-border rounded-full"></span>
            <span class="text-afr-black/60">{formatDate(publication.publishedAt)}</span>
          </div>
          
          <h1 class="text-5xl md:text-7xl font-black leading-tight tracking-tighter">
            {publication.title}
          </h1>
          
          <div class="flex items-center gap-4 py-6 border-y border-afr-border font-sans text-[10px] font-black uppercase tracking-widest">
            <span class="text-afr-red">SPECIAL REPORT</span>
            <span class="w-1.5 h-1.5 rounded-full bg-afr-border"></span>
            <span>{publication.slides.length} PAGES</span>
          </div>

          <p class="text-2xl md:text-3xl text-gray-700 leading-relaxed italic font-normal">
            {publication.excerpt}
          </p>
        </div>
      </div>

      <!-- Slideshow Area -->
      <div class="relative bg-white/50 py-12 px-4 rounded-xl border border-afr-border shadow-inner">
        <PublicationSlideshow slides={publication.slides} title={publication.title} />
      </div>

      <!-- Footer-like Section -->
      <div class="mt-24 border-t-2 border-afr-black pt-12 text-center">
        <p class="font-sans text-[10px] font-black uppercase tracking-[0.4em] text-gray-400">End of Report</p>
      </div>
    </div>
  </main>
</Layout>
