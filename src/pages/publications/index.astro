---
import Layout from '../../layouts/Layout.astro';
import { getPublications, urlFor } from '../../utils/sanity';

const publications = await getPublications();
---

<Layout title="Publications | UNSW FINSOC">
  <main class="pt-32 pb-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <h1 class="text-brand-accent font-black tracking-[0.2em] text-sm mb-4 uppercase">OUR ARCHIVE</h1>
        <h2 class="text-5xl md:text-7xl font-black text-brand-primary tracking-tighter mb-8 leading-[0.9]">FINSOC<br/>PUBLICATIONS.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {publications.length > 0 ? (
          publications.map((pub: any) => (
            <a href={`/publications/${pub.slug.current}`} class="group">
              <div class="aspect-[1/1.414] bg-gray-50 rounded-[2.5rem] overflow-hidden border border-gray-100 shadow-sm group-hover:shadow-2xl transition-all duration-500 mb-8 relative">
                {pub.slides?.[0] && (
                  <img 
                    src={urlFor(pub.slides[0]).width(800).url()} 
                    alt={pub.title}
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                  />
                )}
                <div class="absolute inset-0 bg-brand-primary/0 group-hover:bg-brand-primary/10 transition-colors duration-500 flex items-center justify-center">
                   <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 scale-90 group-hover:scale-100 transition-all duration-500 shadow-xl">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                   </div>
                </div>
              </div>
              <div class="space-y-3 px-2">
                <div class="flex items-center gap-3">
                   <span class="text-brand-accent font-black text-[10px] uppercase tracking-[0.2em]">
                     {new Date(pub.publishedAt).toLocaleDateString(undefined, { month: 'long', year: 'numeric' })}
                   </span>
                </div>
                <h3 class="text-2xl font-black text-brand-primary group-hover:text-brand-accent transition-colors leading-tight">
                  {pub.title}
                </h3>
                <p class="text-gray-500 font-medium line-clamp-2 leading-relaxed">
                  {pub.excerpt}
                </p>
              </div>
            </a>
          ))
        ) : (
          <div class="col-span-full py-20 text-center bg-gray-50 rounded-[3rem] border-4 border-dashed border-gray-100">
            <p class="text-gray-400 font-bold uppercase tracking-widest text-sm">No publications archived yet.</p>
          </div>
        )}
      </div>
    </div>
  </main>
</Layout>
