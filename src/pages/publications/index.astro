---
import Layout from '../../layouts/Layout.astro';
import { getPublications, urlFor } from '../../utils/sanity';

const publications = await getPublications();

// Sort publications by date descending
const sortedPublications = publications.sort((a: any, b: any) => 
  new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
);

const featuredPub = sortedPublications[0];
const remainingPubs = sortedPublications.slice(1);

const formatDate = (date: string) => {
  return new Date(date).toLocaleDateString('en-AU', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
};
---

<Layout title="Publications | UNSW FINSOC">
  <main class="pt-12 pb-24 afr-theme">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">


      <!-- AFR Style Masthead for Section -->
      <div class="border-t-4 border-b border-afr-black py-8 mb-12 text-center">
        <div class="flex flex-col items-center justify-center space-y-2">
          <span class="font-sans text-[10px] font-black tracking-[0.3em] uppercase text-afr-red">The Archive</span>
          <h1 class="text-5xl md:text-7xl font-black tracking-tighter uppercase leading-none font-serif">FINSOC REVIEW</h1>
          <div class="flex items-center gap-4 font-sans text-[10px] font-bold tracking-widest uppercase border-t border-afr-border pt-2 w-full max-w-md justify-center">
            <span>UNSW Sydney</span>
            <span class="w-1 h-1 bg-afr-red rounded-full"></span>
            <span>{new Date().toLocaleDateString('en-AU', { month: 'long', year: 'numeric' })}</span>
          </div>
        </div>
      </div>


      {publications.length > 0 ? (
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
          
          <!-- Featured Article (Newspaper Style) -->
          {featuredPub && (
            <div class="lg:col-span-6 border-b lg:border-b-0 lg:border-r border-afr-border pb-12 lg:pb-0 lg:pr-12">
              <a href={`/publications/${featuredPub.slug.current}`} class="group block">
                <div class="mb-6 relative overflow-hidden bg-white shadow-sm border border-afr-border">
                  {featuredPub.slides?.[0] && (
                    <img 
                      src={urlFor(featuredPub.slides[0]).width(1000).url()} 
                      alt={featuredPub.title}
                      class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                    />
                  )}
                  <div class="absolute top-4 left-4">
                    <span class="bg-afr-red text-white font-sans font-black text-[10px] px-3 py-1 uppercase tracking-widest shadow-lg">
                      Latest Issue
                    </span>
                  </div>
                </div>
                <div class="space-y-4">
                  <div class="flex items-center gap-3 font-sans text-[10px] font-black uppercase tracking-widest text-afr-red">
                    <span>{formatDate(featuredPub.publishedAt)}</span>
                  </div>
                  <h2 class="text-4xl md:text-5xl font-black leading-[1.1] group-hover:text-afr-red transition-colors decoration-afr-red/30 group-hover:underline underline-offset-8">
                    {featuredPub.title}
                  </h2>
                  <p class="text-xl md:text-xl text-gray-700 leading-relaxed max-w-2xl font-normal italic">
                    {featuredPub.excerpt}
                  </p>
                  <div class="pt-4 flex items-center gap-2 font-sans font-black text-xs uppercase tracking-widest group-hover:gap-4 transition-all">
                    Read the full report <span class="text-afr-red">→</span>
                  </div>
                </div>
              </a>
            </div>
          )}

          <!-- Side Column: Remaining Articles -->
          <div class="lg:col-span-4 space-y-10">
            <h3 class="font-sans font-black text-xs uppercase tracking-[0.2em] border-b-2 border-afr-black pb-2 mb-6">Archive Entries</h3>
            {remainingPubs.map((pub: any) => (
              <a href={`/publications/${pub.slug.current}`} class="group block border-b border-afr-border pb-8 last:border-0">
                <div class="space-y-3">
                  <div class="font-sans text-[9px] font-black uppercase tracking-widest text-afr-red">
                    {formatDate(pub.publishedAt)}
                  </div>
                  <h4 class="text-2xl font-black leading-tight group-hover:text-afr-red transition-colors">
                    {pub.title}
                  </h4>
                  <p class="text-sm text-gray-600 font-sans font-medium line-clamp-3 leading-relaxed">
                    {pub.excerpt}
                  </p>
                </div>
              </a>
            ))}

            {remainingPubs.length === 0 && (
              <div class="bg-white/50 p-8 border border-dashed border-afr-border text-center rounded-lg">
                 <p class="font-sans text-[10px] font-bold text-gray-400 uppercase tracking-widest">More issues coming soon</p>
              </div>
            )}
          </div>
        </div>
      ) : (
        <div class="py-32 text-center border-2 border-dashed border-afr-border bg-white/30 rounded-lg">
          <p class="font-sans font-bold uppercase tracking-[0.2em] text-gray-400">The archive is currently being updated.</p>
        </div>
      )}
    </div>
  </main>
</Layout>

<style is:global>
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-serif);
  }
</style>
